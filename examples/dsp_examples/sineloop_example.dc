"dsp.dc" import
"midi.dc" import

var sl1
var sl2
var modwave
make_hc_filter mylp
make_hc_filter mylp2

: sineloop_example
  inf times
    t 0x8f and 0 = if
        refresh_midictl
    endif
      0.1 21 midictl 127 / 6 * +
      sine
    0.5 * 0.5 + 1.284 * modwave !
    # left channel
    sl1 200 modwave @ sineloop 0.53 *
    0.02 panmix
    # right channel
    sl2 300 modwave @ sineloop 0.53 *
    0.98 panmix
    # output
    stereo_out
    t+
  again
;

sineloop_example
