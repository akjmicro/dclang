"string.dc" import

9999 const :PORT
1024 mkbuf const :BUF

udpsocket const :sock
:sock :PORT udpbind 0 = assert

uuid const :id

udpsocket const :send_sock
:send_sock "127.0.0.1" :PORT udpconnect 0 = assert

:send_sock :id :id strlen udpsend
dup 0 > assert
drop

:sock 1000 1024 :BUF udprecv
dup 0 > assert
drop

"Received: " print :BUF print cr

:BUF :id str= assert

:send_sock udpclose 0 = assert
:sock udpclose 0 = assert
