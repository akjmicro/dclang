# Meant to be called via the bash script, `run_tests.sh`
# ...in case /tmp/keys doesn't exist, that script will create it

"music.dc" import

: test_do_symbol_string
  # set to standard 12-edo and make a little arpeggio
  "12"               "edo" keyval_set
  "C Eb G Bb"       "sym1" keyval_set
  # test iteration
  do_symbol_string   0  = assert
  do_symbol_string   3  = assert
  do_symbol_string   7  = assert
  do_symbol_string  10  = assert
  do_symbol_string   0  = assert
  # Now, 31-edo, and a little scale and octave drop
  "31"               "edo" keyval_set
  "C D E G A# C2"   "sym1" keyval_set
  do_symbol_string   0  = assert
  do_symbol_string   5  = assert
  do_symbol_string  10  = assert
  do_symbol_string  18  = assert
  do_symbol_string  25  = assert
  do_symbol_string -62  = assert
  "53"               "edo" keyval_set
  "A5 C#v6 E6"      "sym1" keyval_set
  do_symbol_string  93  = assert
  do_symbol_string 110  = assert
  do_symbol_string 124  = assert
;

test_do_symbol_string

: _test_token { s }
  _seq_token_buf @ 0 128 memset
  _seq_token_buf @ s dup strlen 1 + mempcpy drop
  _seq_token_buf @
;

: test_seq_helpers
  "12" "edo" keyval_set

  "edo=31" _token_has_equals? true = assert
  "1\\4"   _token_has_backslash? true = assert
  "1/1"    _token_has_slash? true = assert
  "4:5"    _token_has_colon? true = assert

  5 4 _ratio_to_edo_delta 4 = assert
  6 5 _ratio_to_edo_delta 3 = assert
  5 6 _ratio_to_edo_delta -3 = assert

  "1/1" _test_token _parse_abs_ratio_token 0 = assert
  "5/4" _test_token _parse_abs_ratio_token 4 = assert
  "3/2" _test_token _parse_abs_ratio_token 7 = assert

  "4:5" _test_token _parse_rel_ratio_token 4 = assert
  "5:6" _test_token _parse_rel_ratio_token 3 = assert
  "6:5" _test_token _parse_rel_ratio_token -3 = assert

  "1\\4" _test_token _process_duration_token
  _seq_duration @ 1 = assert

  "1\\8" _test_token _process_duration_token
  _seq_duration @ 0.5 = assert

  "3\\16" _test_token _process_duration_token
  _seq_duration @ 0.75 = assert
;

test_seq_helpers

: test_do_seq_string
  "12" "edo" keyval_set
  "1\\4 1/1 4:5 5:6 6:5 C G" "seq1" keyval_set
  do_seq_string   0 = assert
  _seq_duration @  1 = assert
  do_seq_string   4 = assert
  do_seq_string   7 = assert
  do_seq_string   4 = assert
  do_seq_string   0 = assert
  do_seq_string   7 = assert
  "12" "edo" keyval_set
  "1/1 17:18 18:19 19:20" "seq1" keyval_set
  do_seq_string   0 = assert
  do_seq_string   1 = assert
  do_seq_string   2 = assert
  do_seq_string   3 = assert
  "31" "edo" keyval_set
  "1\\16 1/1 4:5 5:6 6:5 edo=12 4:5" "seq1" keyval_set
  do_seq_string   0 = assert
  _seq_duration @ 0.25 = assert
  do_seq_string  10 = assert
  do_seq_string  18 = assert
  do_seq_string  10 = assert
  do_seq_string  14 = assert
;

test_do_seq_string
